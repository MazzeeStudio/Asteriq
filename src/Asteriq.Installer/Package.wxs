<?xml version="1.0" encoding="UTF-8"?>
<!--
  Asteriq MSI Installer — WiX v6
  UpgradeCode is fixed for the lifetime of the product. NEVER change it.
  Version and SourceDir are passed in at build time by publish.ps1.

  Install location: %LocalAppData%\Asteriq  (per-user, no UAC required)

  NOTE: When new device SVGs or map JSONs are added under Images/, add a
  corresponding <Component> entry in the DeviceImageFiles or DeviceMapFiles
  ComponentGroup below, then rebuild the MSI.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="Asteriq"
           Manufacturer="Mazzee Studio"
           Version="$(var.Version)"
           UpgradeCode="{2902A093-3E1F-45CC-86AD-0B1DB28BE088}"
           Scope="perUser"
           Compressed="yes">

    <SummaryInformation Description="Asteriq HOTAS Manager for Star Citizen" />

    <!-- Clean upgrade: removes old version before installing new one. Blocks downgrades. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Asteriq is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Add/Remove Programs appearance -->
    <Icon Id="AsteriqIcon" SourceFile="$(var.SourceDir)\asteriq.ico" />
    <Property Id="ARPPRODUCTICON"  Value="AsteriqIcon" />
    <Property Id="ARPHELPLINK"     Value="https://github.com/MazzeeStudio/Asteriq" />
    <Property Id="ARPURLINFOABOUT" Value="https://mazzeestudio.github.io/Asteriq/" />

    <!-- Directory layout -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="Asteriq">
        <Directory Id="ImagesDir" Name="Images">
          <Directory Id="DevicesDir" Name="Devices">
            <Directory Id="MapsDir" Name="Maps" />
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuAsteriq" Name="Asteriq" />
    </StandardDirectory>

    <Feature Id="Main" Title="Asteriq" Level="1">
      <ComponentGroupRef Id="RootFiles" />
      <ComponentGroupRef Id="DeviceImageFiles" />
      <ComponentGroupRef Id="DeviceMapFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>

  <!-- ═══════════════════════════════════════════════════
       Root application files
       ═══════════════════════════════════════════════════ -->
  <Fragment>
    <ComponentGroup Id="RootFiles" Directory="INSTALLFOLDER">

      <Component Id="AsteriqExe">
        <File Source="$(var.SourceDir)\Asteriq.exe" KeyPath="yes" />
      </Component>

      <Component Id="VJoyDll">
        <File Source="$(var.SourceDir)\vJoyInterface.dll" KeyPath="yes" />
      </Component>

      <Component Id="IcoFile">
        <File Source="$(var.SourceDir)\asteriq.ico" KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- ═══════════════════════════════════════════════════
       Device silhouette SVGs  (Images\Devices\)
       Add a new Component here for each new device SVG.
       ═══════════════════════════════════════════════════ -->
  <Fragment>
    <ComponentGroup Id="DeviceImageFiles" Directory="DevicesDir">

      <Component Id="ImgJoystick">
        <File Source="$(var.SourceDir)\Images\Devices\joystick.svg" KeyPath="yes" />
      </Component>

      <Component Id="ImgThrottle">
        <File Source="$(var.SourceDir)\Images\Devices\throttle.svg" KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- ═══════════════════════════════════════════════════
       Device control map JSONs  (Images\Devices\Maps\)
       Add a new Component here for each new device map.
       ═══════════════════════════════════════════════════ -->
  <Fragment>
    <ComponentGroup Id="DeviceMapFiles" Directory="MapsDir">

      <Component Id="MapSchema">
        <File Source="$(var.SourceDir)\Images\Devices\Maps\device-control-map.schema.json" KeyPath="yes" />
      </Component>

      <Component Id="MapJoystick">
        <File Source="$(var.SourceDir)\Images\Devices\Maps\joystick.json" KeyPath="yes" />
      </Component>

      <Component Id="MapThrottle">
        <File Source="$(var.SourceDir)\Images\Devices\Maps\throttle.json" KeyPath="yes" />
      </Component>

      <Component Id="MapVirpilAlphaPrimeL">
        <File Source="$(var.SourceDir)\Images\Devices\Maps\virpil_alpha_prime_l.json" KeyPath="yes" />
      </Component>

      <Component Id="MapVirpilAlphaPrimeR">
        <File Source="$(var.SourceDir)\Images\Devices\Maps\virpil_alpha_prime_r.json" KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- ═══════════════════════════════════════════════════
       Start Menu shortcut
       ═══════════════════════════════════════════════════ -->
  <Fragment>
    <Component Id="StartMenuShortcut" Directory="ProgramMenuAsteriq">
      <Shortcut Id="StartMenuShortcutItem"
                Name="Asteriq"
                Description="Asteriq HOTAS Manager for Star Citizen"
                Target="[INSTALLFOLDER]Asteriq.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AsteriqIcon" />
      <!-- Clean up the Start Menu folder on uninstall -->
      <RemoveFolder Id="RemoveProgramMenuAsteriq" Directory="ProgramMenuAsteriq" On="uninstall" />
      <!-- Registry key path required by Windows Installer for the shortcut component -->
      <RegistryValue Root="HKCU"
                     Key="Software\MazzeeStudio\Asteriq"
                     Name="StartMenuShortcut"
                     Type="integer" Value="1"
                     KeyPath="yes" />
    </Component>
  </Fragment>

</Wix>
