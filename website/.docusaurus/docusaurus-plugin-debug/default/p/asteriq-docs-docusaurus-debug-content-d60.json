{"allContent":{"docusaurus-plugin-css-cascade-layers":{},"docusaurus-plugin-content-docs":{"default":{"loadedVersions":[{"versionName":"current","label":"Next","banner":null,"badge":false,"noIndex":false,"className":"docs-version-current","path":"/Asteriq/docs/","tagsPath":"/Asteriq/docs/tags","isLast":true,"routePriority":-1,"sidebarFilePath":"C:\\Users\\mhams\\source\\repos\\Asteriq\\website\\sidebars.ts","contentPath":"C:\\Users\\mhams\\source\\repos\\Asteriq\\website\\docs","docs":[{"id":"client-only","title":"Client Only Mode","description":"Client Only Mode is designed for RX machines in a network forwarding setup. When enabled, Asteriq hides the Devices and Mappings tabs, leaving only the SC Bindings and Settings tabs visible.","source":"@site/docs/client-only.md","sourceDirName":".","slug":"/client-only","permalink":"/Asteriq/docs/client-only","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":8,"frontMatter":{"sidebar_position":8,"title":"Client Only Mode"},"sidebar":"docsSidebar","previous":{"title":"Settings","permalink":"/Asteriq/docs/settings"}},{"id":"devices","title":"Devices","description":"The Devices tab is the starting point for any Asteriq setup. It shows all connected physical controllers and your configured vJoy virtual devices, and is where you assign physical inputs to virtual outputs and start or stop forwarding.","source":"@site/docs/devices.md","sourceDirName":".","slug":"/devices","permalink":"/Asteriq/docs/devices","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":3,"frontMatter":{"sidebar_position":3,"title":"Devices"},"sidebar":"docsSidebar","previous":{"title":"Getting Started","permalink":"/Asteriq/docs/getting-started"},"next":{"title":"Mappings","permalink":"/Asteriq/docs/mappings"}},{"id":"getting-started","title":"Getting Started","description":"This page walks you through setting up Asteriq from scratch — from installation to your first forwarding session.","source":"@site