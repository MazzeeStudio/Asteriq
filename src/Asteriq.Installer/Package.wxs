<?xml version="1.0" encoding="UTF-8"?>
<!--
  Asteriq MSI Installer — WiX v6
  UpgradeCode is fixed for the lifetime of the product. NEVER change it.
  Version and SourceDir are passed in at build time by publish.ps1.

  Install location: C:\Program Files\Asteriq  (per-machine, requires UAC)

  NOTE: When new device SVGs or map JSONs are added under Images/, add a
  corresponding <Component> entry in the DeviceImageFiles or DeviceMapFiles
  ComponentGroup below, then rebuild the MSI.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Asteriq"
           Manufacturer="Mazzee Studio"
           Version="$(var.Version)"
           UpgradeCode="{2902A093-3E1F-45CC-86AD-0B1DB28BE088}"
           Scope="perMachine"
           Compressed="yes">

    <SummaryInformation Description="Asteriq HOTAS Manager for Star Citizen" />

    <!-- Clean upgrade: removes old version before installing new one. Blocks downgrades. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Asteriq is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Add/Remove Programs appearance -->
    <Icon Id="AsteriqIcon" SourceFile="$(var.SourceDir)\asteriq.ico" />
    <Property Id="ARPPRODUCTICON"  Value="AsteriqIcon" />
    <Property Id="ARPHELPLINK"     Value="https://github.com/MazzeeStudio/Asteriq" />
    <Property Id="ARPURLINFOABOUT" Value="https://mazzeestudio.github.io/Asteriq/" />

    <!-- Installer UI: Welcome/License → Progress → Finish dialog -->
    <WixVariable Id="WixUILicenseRtf" Value="$(var.InstallerDir)\License.rtf" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Asteriq" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX"     Value="1" />
    <ui:WixUI Id="WixUI_Minimal" />

    <!--
      Launch Asteriq when the user clicks Finish with the checkbox checked.
      Must live inside Package (not a Fragment) so it is never pruned.
      Property="ComSpec" runs cmd.exe; 'start ""' opens Asteriq in the
      user's desktop session as its own process.
    -->
    <!--
      WixShellExec is the canonical WiX approach: uses ShellExecute API directly,
      no cmd.exe or process-spawning workarounds needed.
      $(sys.BUILDARCHSHORT) resolves to X86/X64/A64 automatically.
      [#AsteriqExeFile] references the installed file by its MSI file ID.
    -->
    <Property Id="WixShellExecTarget" Value="[#AsteriqExeFile]" />
    <CustomAction Id="LaunchAsteriq"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
                  DllEntry="WixShellExec"
                  Impersonate="yes"
                  Return="ignore" />

    <UI>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction"
               Value="LaunchAsteriq" Order="1"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>

    <!-- Directory layout -->
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="INSTALLFOLDER" Name="Asteriq">
        <Directory Id="ImagesDir" Name="Images">
          <Directory Id="DevicesDir" Name="Devices">
            <Directory Id="MapsDir" Name="Maps" />
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuAsteriq" Name="Asteriq" />
    </StandardDirectory>

    <Feature Id="Main" Title="Asteriq" Level="1">
      <ComponentGroupRef Id="RootFiles" />
      <ComponentGroupRef Id="DeviceImageFiles" />
      <ComponentGroupRef Id="DeviceMapFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>

  <!-- ═══════════════════════════════════════════════════
       Root application files
       ═══════════════════════════════════════════════════ -->
  <Fragment>
    <ComponentGroup Id="RootFiles" Directory="INSTALLFOLDER">

      <Component Id="AsteriqExe">
        <File Id="AsteriqExeFile" Source="$(var.SourceDir)\Asteriq.exe" KeyPath="yes" />
      </Component>

      <Component Id="VJoyDll">
        <File Source="$(var.SourceDir)\vJoyInterface.dll" KeyPath="yes" />
      </Component>

      <Component Id="IcoFile">
        <File Source="$(var.SourceDir)\asteriq.ico" KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

