work-forwarding.md","sourceDirName":".","slug":"/network-forwarding","permalink":"/Asteriq/docs/network-forwarding","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":6,"frontMatter":{"sidebar_position":6,"title":"Network Forwarding"},"sidebar":"docsSidebar","previous":{"title":"SC Bindings","permalink":"/Asteriq/docs/sc-bindings"},"next":{"title":"Settings","permalink":"/Asteriq/docs/settings"}},{"id":"sc-bindings","title":"SC Bindings","description":"The SC Bindings tab lets you load a Star Citizen control profile, assign inputs to SC actions across your devices, detect binding conflicts, and export a ready-to-use profile to your Star Citizen directory.","source":"@site/docs/sc-bindings.md","sourceDirName":".","slug":"/sc-bindings","permalink":"/Asteriq/docs/sc-bindings","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":5,"frontMatter":{"sidebar_position":5,"title":"SC Bindings"},"sidebar":"docsSidebar","previous":{"title":"Mappings","permalink":"/Asteriq/docs/mappings"},"next":{"title":"Network Forwarding","permalink":"/Asteriq/docs/network-forwarding"}},{"id":"settings","title":"Settings","description":"The Settings tab covers configuration management, system driver status, network forwarding setup, visual themes, and general application preferences.","source":"@site/docs/settings.md","sourceDirName":".","slug":"/settings","permalink":"/Asteriq/docs/settings","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":7,"frontMatter":{"sidebar_position":7,"title":"Settings"},"sidebar":"docsSidebar","previous":{"title":"Network Forwarding","permalink":"/Asteriq/docs/network-forwarding"},"next":{"title":"Client Only Mode","permalink":"/Asteriq/docs/client-only"}}],"drafts":[],"sidebars":{"docsSidebar":[{"type":"doc","id":"intro"},{"type":"doc","id":"getting-started"},{"type":"category","label":"Features","collapsed":false,"items":[{"type":"doc","id":"devices"},{"type":"doc","id":"mappings"